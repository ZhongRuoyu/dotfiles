[user]
  name = Ruoyu Zhong
  email = zhongruoyu@outlook.com
[core]
  excludesFile = ~/.config/git/ignore
[init]
  defaultBranch = main
[checkout]
  defaultRemote = origin
[commit]
  verbose = true
[diff]
  algorithm = histogram
[log]
  decorate = auto
[merge]
  autoStash = true
[rebase]
  autoStash = true
[fetch]
  all = true
  prune = true
  pruneTags = true
  writeCommitGraph = true
[pull]
  rebase = true
[push]
  autoSetupRemote = true
[gc]
  writeCommitGraph = true
[rerere]
  enabled = true
[gpg "ssh"]
  allowedSignersFile = ~/.ssh/allowed_signers

[alias]
  alias = "!alias() { \
      : git config get; \
      if [ \"$#\" -eq 0 ]; then \
        git config get --all --show-names --regexp '^alias\\..+'; \
      else \
        for alias in \"$@\"; do :; done; \
        i=0; \
        while [ \"$((i+=1))\" -lt \"$#\" ]; do \
          set -- \"$@\" \"$1\"; \
          shift; \
        done; \
        shift; \
        git config get \"$@\" alias.\"$alias\"; \
      fi; \
    }; alias"
  a = add
  ap = apply
  ar = archive
  bs = bisect
  bsb = bisect bad
  bsg = bisect good
  bsn = bisect new
  bso = bisect old
  bsr = bisect reset
  bss = bisect start
  bl = blame
  b = branch
  bdm = "!bdm() { \
      :; \
      git for-each-ref --merged=HEAD --format='%(refname:short)' refs/heads | \
        grep -Fvx -e \"$(git branch --show-current)\" | \
        tr '\\n' '\\0' | \
        xargs -0 -r git branch --delete; \
    }; bdm"
  bsup = !git branch --set-upstream-to=origin/\"$(git symbolic-ref --short HEAD)\"
  co = checkout
  cor = checkout --recurse-submodules
  cp = cherry-pick
  cpa = cherry-pick --abort
  cpc = cherry-pick --continue
  cl = clone
  clr = clone --recurse-submodules
  c = commit
  cam = commit --amend
  cfu = commit --fixup
  cre = commit --reedit-message=ORIG_HEAD
  cru = commit --reuse-message=ORIG_HEAD
  cf = config
  cfg = config get
  cfl = config list
  cfs = config set
  cfrm = config unset
  ds = describe
  dst = describe --tags
  d = diff
  dc = diff --cached
  du = diff @{upstream}
  dw = diff --word-diff
  f = fetch
  fa = fetch --all
  fo = fetch origin
  lg = log
  lga = log --oneline --graph --all
  lgg = log --oneline --graph
  lgs = log --stat
  lgss = log --show-signature
  ls = ls-files
  m = merge
  ma = merge --abort
  mc = merge --continue
  ms = merge --squash
  mom = !git merge \"$(git symbolic-ref --short refs/remotes/origin/HEAD)\"
  mum = !git merge \"$(git symbolic-ref --short refs/remotes/upstream/HEAD)\"
  mb = merge-base
  mbom = !git merge-base \"$(git symbolic-ref --short refs/remotes/origin/HEAD)\"
  mbum = !git merge-base \"$(git symbolic-ref --short refs/remotes/upstream/HEAD)\"
  l = pull
  las = pull --autostash
  p = push
  pu = !git push --set-upstream origin \"$(git symbolic-ref --short HEAD)\"
  rb = rebase
  rba = rebase --abort
  rbc = rebase --continue
  rbe = rebase --edit-todo
  rbi = rebase --interactive
  rbo = rebase --onto
  rbs = rebase --skip
  rbom = !git rebase \"$(git symbolic-ref --short refs/remotes/origin/HEAD)\"
  rbum = !git rebase \"$(git symbolic-ref --short refs/remotes/upstream/HEAD)\"
  rl = reflog
  r = remote
  ra = remote add
  rmv = remote rename
  rrm = remote remove
  rrr = rerere
  rh = reset
  rhh = reset --hard
  rhk = reset --keep
  rhs = reset --soft
  rhhu = reset --hard @{upstream}
  rs = restore
  rv = revert
  rva = revert --abort
  rvc = revert --continue
  rp = rev-parse
  rpa = rev-parse --abbrev-ref
  rmc = rm --cached
  sh = show
  sheml = show --format=email
  shref = show --no-patch --format=reference
  sb = show-branch
  sta = stash
  staa = stash apply
  std = stash drop
  stl = stash list
  stp = stash pop
  sts = stash show
  stss = stash show --stat
  stssp = stash show --stat --patch
  s = status
  sm = submodule
  sma = submodule add
  smi = submodule init
  sms = submodule status
  smu = submodule update
  smur = submodule update --recursive
  sw = switch
  swr = switch --recurse-submodules
  sr = symbolic-ref
  srs = symbolic-ref --short
  t = tag
  tls = tag --list --sort=-version:refname
  wt = worktree
  wta = worktree add
  wtls = worktree list
  wtmv = worktree move
  wtrm = worktree remove

[include]
  path = ~/.config/git/config.local

